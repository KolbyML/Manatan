<component type="desktop-application">
  <id>io.github.kolbyml.Manatan</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Manatan</name>
  <summary>Learn languages with your media</summary>
  <developer id="io.github.kolbyml">
    <name>Manatan Team</name>
  </developer>
  <description>
    <p>
      Manatan is an immersion language-learning app for watching anime and
      reading manga, light novels, and EPUBs with instant word lookup.
    </p>
    <p>It brings the complete learning workflow into one desktop app:</p>
    <ul>
      <li>Selectable subtitles and popup dictionary lookups while watching video</li>
      <li>Built-in OCR and instant lookup while reading manga</li>
      <li>EPUB and light-novel reading with progress synchronization</li>
      <li>One-click Anki cards with sentence text, images, and audio</li>
      <li>Local media libraries and supported extension sources</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.kolbyml.Manatan.desktop</launchable>
  <provides>
    <binary>manatan</binary>
  </provides>
  <categories>
    <category>Education</category>
  </categories>
  <keywords>
    <keyword>language learning</keyword>
    <keyword>anime</keyword>
    <keyword>manga</keyword>
    <keyword>subtitles</keyword>
    <keyword>OCR</keyword>
    <keyword>Anki</keyword>
  </keywords>
  <url type="homepage">https://manatan.com/</url>
